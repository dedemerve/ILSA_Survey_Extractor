    "main_findings": [
      {
        "dataset_used": "PISA 2022 Spain (15-year-olds) — student contextual variables (74 variables; 16 derived factors)",
        "target_variable": "Student cluster membership (7 clusters)",
        "top_predictors": [
          "Socioeconomic status (ESCS)",
          "ICT availability and usage at home",
          "ICT availability and usage at school",
          "Gender"
        ],
        "performance_metrics": "Best classification pipeline — global accuracy: 0.8643 (test set); precision: 0.8401–0.9321; recall: 0.8055–0.9406. Cluster interpretability via global and local SHAP values.",
        "standardized_conclusion": "Using PISA 2022 Spain the study leveraged socioeconomic status (ESCS), ICT use at home and school, and gender to classify students into 7 explainable clusters, finding that ESCS and ICT-use variables had the highest predictive power for cluster membership and that the best model achieved 0.8643 test accuracy. The interpretability relied on SHAP (predictive importance, not causal effects), and the paper does not document complex-survey weight application for the ML models. This indicates that these patterns have implications for educational policy and instructional practice, though cross-sectional ILSA designs cannot establish causality."
      },
      {
        "dataset_used": "PISA 2022 Spain (15-year-olds) — cluster profiles",
        "target_variable": "Academic performance differences across clusters (Math/Science/Reading)",
        "top_predictors": [
          "Socioeconomic status (ESCS)",
          "Gender",
          "ICT availability and usage at home",
          "Family support"
        ],
        "performance_metrics": "Not reported as a single predictive metric; reported observed/expected performance by cluster (Table B.5) and qualitative differences across clusters.",
        "standardized_conclusion": "Using PISA 2022 Spain cluster profiles, the study examined how clusters differed in academic performance across Mathematics, Science, and Reading, finding substantial between-cluster disparities even though PISA test scores were not used for clustering. The results suggest that support networks and ICT-related factors are associated with achievement patterns, with stronger ESCS-related effects among higher-SES students. Because the clustering was unsupervised and SHAP was used for interpretability of the classification step, the findings should be interpreted as associations rather than causal impacts. This indicates that these patterns have implications for educational policy and instructional practice, though cross-sectional ILSA designs cannot establish causality."
      }
    ],
    "outcome_summary": "The paper proposes an explainable cluster-analysis pipeline for PISA 2022 Spanish students, using the full student sample (n = 30,800) and 74 contextual variables reduced to 16 derived factors. Students were clustered with k-means into an optimal 7-cluster solution, and cluster interpretability was supported by a supervised classification stage using SHAP (global and local) to identify which variables best characterize each cluster. The best-performing classification pipeline achieved 0.8643 global accuracy on the test set, with precision between 0.8401 and 0.9321 and recall between 0.8055 and 0.9406. ESCS and ICT use at home and school were identified as the strongest predictive features for cluster membership. The study reports meaningful differences in academic performance across clusters (Math/Science/Reading) despite not using test scores for clustering, but the paper does not document complex-survey weighting for the ML models and SHAP-based importance should not be treated as causal evidence.",
    "research_design_type": "predictive",
    "null_fields_interpretation": null
  }
